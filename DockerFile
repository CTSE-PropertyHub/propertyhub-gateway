# Stage 1: Build
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /app

# Copy project file first for layer caching — restore only re-runs when dependencies change
COPY src/PropertyHub.Gateway/*.csproj ./src/PropertyHub.Gateway/

# Restore NuGet packages
RUN dotnet restore src/PropertyHub.Gateway/PropertyHub.Gateway.csproj

# Copy everything else and build
COPY . .
RUN dotnet publish src/PropertyHub.Gateway/PropertyHub.Gateway.csproj \
    -c Release \
    -o /app/publish

# Stage 2: Runtime (smaller final image)
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

# Copy only the published output from the build stage
COPY --from=build /app/publish .

# Tell Azure Container Apps which port to expect
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

ENTRYPOINT ["dotnet", "PropertyHub.Gateway.dll"]