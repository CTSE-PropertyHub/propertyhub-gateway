{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Gateway": {
    "JwtAuthority": "https://auth-service.internal.victorioussky-43640679.eastasia.azurecontainerapps.io",
    "JwtIssuer": "https://auth.propertyhub.internal",
    "JwtAudience": "propertyhub-api",
    "BrokenCircuitRetryAfterSeconds": 30
  },

  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/auth/{**catch-all}" }
      },

      "properties-route": {
        "ClusterId": "property-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/properties/{**catch-all}" }
      },

      "tenancy-route": {
        "ClusterId": "tenancy-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/tenancy/{**catch-all}" }
      },

      "inspections-route": {
        "ClusterId": "inspection-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/inspections/{**catch-all}" }
      }

    },
    "Clusters": {

      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://auth-service" }
        }
      },

      "property-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://property-service" }
        }
      },

      "tenancy-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://tenancy-service" }
        }
      },

      "inspection-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://inspection-service" }
        }
      }

    }
  }
}
