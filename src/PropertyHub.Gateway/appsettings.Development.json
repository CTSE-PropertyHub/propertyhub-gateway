{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Yarp.ReverseProxy": "Debug",
      "PropertyHub.Gateway": "Debug"
    }
  },

  "Gateway": {
    "JwtAuthority": "http://localhost:5100",
    "JwtIssuer": "http://localhost:5100",
    "JwtAudience": "propertyhub-api"
  },

  "ReverseProxy": {
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5100" }
        }
      },
      "property-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5101" }
        }
      },
      "tenancy-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5102" }
        }
      },
      "inspection-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5103" }
        }
      }
    }
  }
}
